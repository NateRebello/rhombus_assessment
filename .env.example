# Django
DJANGO_SECRET_KEY=change-me-in-production-use-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# Postgres (used by docker-compose db service; DATABASE_URL is what Django reads)
POSTGRES_DB=rhombus
POSTGRES_USER=rhombus
POSTGRES_PASSWORD=rhombus
DATABASE_URL=postgres://rhombus:rhombus@db:5432/rhombus

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
REGEX_CACHE_TTL_SECONDS=3600

# LLM
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30

# PySpark (read by spark_jobs/session.py inside the worker container)
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=1g
SPARK_MASTER_URL=local[*]

# File storage (absolute paths inside containers)
UPLOAD_DIR=/app/uploads
RESULT_DIR=/app/results

# Frontend dev server (Vite)
VITE_API_BASE_URL=http://localhost:8000

# Optional — only needed when frontend runs on a separate origin
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
