# ── Django / General ──────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production-use-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=rhombus
POSTGRES_USER=rhombus
POSTGRES_PASSWORD=rhombus
DATABASE_URL=postgres://rhombus:rhombus@db:5432/rhombus

# ── Redis / Celery ────────────────────────────────────────────────────────────
# Both broker and result-backend point at the same Redis instance.
# A separate DB index (e.g. /1) could be used for the result backend, but /0
# is fine for development.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Cache for LLM-generated regexes (sha256(prompt) -> regex string).
REDIS_CACHE_URL=redis://redis:6379/1

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Model used for NL -> regex generation.
LLM_MODEL=gpt-4o-mini
# Seconds to wait for an LLM response before raising a timeout error (retryable).
LLM_TIMEOUT_SECONDS=30

# ── PySpark ───────────────────────────────────────────────────────────────────
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=1g

# ── File storage ─────────────────────────────────────────────────────────────
# Absolute paths inside the container (mounted as Docker volumes).
UPLOAD_DIR=/app/uploads
RESULT_DIR=/app/results

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
