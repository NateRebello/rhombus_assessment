# .env.production.example
# Production secrets template for the AWS EC2 / sslip.io deployment.
#
# Copy this to .env on the server and fill in every REPLACE_ME value.
# NEVER commit the filled-in .env — it is excluded by .gitignore.
#
#   scp -i ~/.ssh/rhombus-key.pem .env.production.example ubuntu@<ELASTIC_IP>:~/rhombus_assessment/.env
#   ssh -i ~/.ssh/rhombus-key.pem ubuntu@<ELASTIC_IP>
#   nano ~/rhombus_assessment/.env
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
# Use a DIFFERENT key from your local dev .env — never share keys across envs.
DJANGO_SECRET_KEY=3SATKLOckvqkTXpFgWQMa4ncNR3s-7SCMP3gi1YMlsSHqPWAbvOwhCD_7iqG_J66RMY

DJANGO_DEBUG=False

# Include both the raw Elastic IP and the sslip.io hostname.
# Example: DJANGO_ALLOWED_HOSTS=1.2.3.4,1-2-3-4.sslip.io
# (Caddy forwards the original Host header to Django, so Django must recognise it)
DJANGO_ALLOWED_HOSTS=15.134.239.205,15-134-239-205.sslip.io

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=rhombus
POSTGRES_USER=rhombus
# Generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
POSTGRES_PASSWORD=672f4fda40e31a04f694820bb1c87b5cbfe208e54429473b
DATABASE_URL=postgres://rhombus:672f4fda40e31a04f694820bb1c87b5cbfe208e54429473b@db:5432/rhombus

# ── Celery / Redis ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=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

# ── Frontend API base URL ─────────────────────────────────────────────────────
# EMPTY — because frontend and backend share the same origin (both served from
# the sslip.io hostname), the React app uses a relative /api/ path.
# The browser sends requests to the same server that served the page, so
# Caddy intercepts /api/* and proxies to Django with NO cross-origin request.
# CORS headers are never needed or sent.
VITE_API_BASE_URL= 

# ── Caddy hostname ────────────────────────────────────────────────────────────
# Replace dots in the Elastic IP with hyphens, then append .sslip.io
# Example: Elastic IP 1.2.3.4 → CADDY_HOSTNAME=1-2-3-4.sslip.io
# Caddy will obtain a real Let's Encrypt certificate for this hostname automatically.
# To use a custom domain later, just change this to yourdomain.com — nothing else changes.
CADDY_HOSTNAME=15-134-239-205.sslip.io

# ── Spark + worker memory (t3.medium — 4 GB) ─────────────────────────────────
# See docker-compose.prod.yml for the memory budget breakdown.
WORKER_MEM_LIMIT=2g
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=512m

# ── Optional tuning ───────────────────────────────────────────────────────────
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
REGEX_CACHE_TTL_SECONDS=3600
